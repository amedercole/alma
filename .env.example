# Copy to `.env` and fill in. Local defaults below work with `docker compose up`.

# --- Database (Postgres) ---
# Local docker-compose default. On Railway, use the injected DATABASE_URL.
DATABASE_URL="postgresql://alma:alma@localhost:5432/alma?schema=public"

# --- Auth ---
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Email ---
# Provider is auto-selected: SMTP (if SMTP_HOST set) > Resend (if key set) >
# console (logs only). Configure ONE of the two below.
#
# Option A — SMTP, e.g. Gmail (sends FROM your own address, no domain needed).
#   Gmail requires 2-Step Verification + an "App Password" (not your login pw).
#   Then set EMAIL_FROM to that same address.
SMTP_HOST=""          # e.g. smtp.gmail.com
SMTP_PORT="587"       # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=""          # e.g. you@gmail.com
SMTP_PASS=""          # 16-char Gmail App Password
#
# Option B — Resend (needs a verified domain to send from your own address).
RESEND_API_KEY=""
#
# The From address shown to recipients. For Gmail SMTP use your own address:
EMAIL_FROM="Alma Leads <onboarding@resend.dev>"
# Inbox that receives the attorney notification when a lead is submitted.
ATTORNEY_NOTIFY_EMAIL="attorney@example.com"

# --- Storage (resume/CV files) ---
# `local` writes to disk (mount a Railway volume at STORAGE_LOCAL_DIR in prod).
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage/uploads"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Seed (optional; defaults applied if unset) ---
SEED_ATTORNEY_EMAIL="attorney@alma.test"
SEED_ATTORNEY_PASSWORD="password123"
SEED_ATTORNEY_NAME="Alma Attorney"
