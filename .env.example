# Copy to `.env` and fill in. Local defaults below work with `docker compose up`.

# --- Database (Postgres) ---
# Local docker-compose default. On Railway, use the injected DATABASE_URL.
DATABASE_URL="postgresql://alma:alma@localhost:5432/alma?schema=public"

# --- Auth ---
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Email (Resend) ---
# Leave RESEND_API_KEY empty to log emails to the console instead of sending.
RESEND_API_KEY=""
EMAIL_FROM="Alma Leads <onboarding@resend.dev>"
# Inbox that receives the attorney notification when a lead is submitted.
ATTORNEY_NOTIFY_EMAIL="attorney@example.com"

# --- Storage (resume/CV files) ---
# `local` writes to disk (mount a Railway volume at STORAGE_LOCAL_DIR in prod).
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage/uploads"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Seed (optional; defaults applied if unset) ---
SEED_ATTORNEY_EMAIL="attorney@alma.test"
SEED_ATTORNEY_PASSWORD="password123"
SEED_ATTORNEY_NAME="Alma Attorney"
